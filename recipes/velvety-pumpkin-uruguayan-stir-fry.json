  "ingredients": [
    {
      "name": "pumpkin",
      "amount": "1 cup peeled and diced"
    },
    {
      "name": "shallots",
      "amount": "3 slices thinly sliced"
    },
    {
      "name": "onion",
      "amount": "1/4 medium, finely chopped"
    },
    {
      "name": "peel of 1 lime",
      "notes": "juiced"
    },
    {
      "name": "coconut milk",
      "amount": "2 cups"
    },
    {
      "name": "butter",
      "amount": "3 tbsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat butter in a pan over medium heat.",
    "Add shallots and onion, saut\u00e9 until translucent and fragrant. Add lime peel and cook for an additional minute.",
    "Stir in pumpkin and coconut milk, adjust seasoning with salt if needed, bring to boil.",
    "Reduce heat to low and let simmer for 20 minutes or until the pumpkin is very soft.",
    "Blend mixture until smooth using a hand blender. Season with lime juice as desired."
  ],
