{
  "title": "Velvety Pumpkin Uruguayan Stir-fry",
  "description": "A quick-fix nutty and velvety dish featuring melons in a bhuna-style sauce that is both wholesome and delicious.",
  "cuisine": "Uruguayan",
  "diet": [
    "nutty",
    "velvety",
