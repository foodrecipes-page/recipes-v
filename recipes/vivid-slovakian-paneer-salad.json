{
  "title": "Vivid Slovakian Paneer Salad",
  "description": "A sour, snappy salad that blends paneer with bright pickled cucumbers and fresh veggies, perfect for a lazy Sunday lunch.",
  "cuisine": "Slovakian",
  "diet": [
    "vegetarian",
