      "name": "paneer",
      "amount": "200g",
      "notes": "cut into 1/2 inch cubes"
    },
    {
      "name": "nuka-pickle",
      "amount": "50g",
      "notes": "finely chopped"
    },
    {
      "name": "cucumber",
      "amount": "1 medium",
      "notes": "peeled and diced"
    },
    {
      "name": "cherry tomatoes",
      "amount": "10",
      "notes": "halved"
    },
    {
      "name": "bell pepper",
      "amount": "1/2",
      "notes": "diced"
    },
    {
      "name": "dill",
      "amount": "1 tbsp",
      "notes": "chopped"
    },
    {
      "name": "lemon juice",
      "amount": "1 tbsp"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "parsley",
      "amount": "1 tbsp",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Cube the paneer and set aside.",
    "Dice the cucumber, bell pepper, and chop the dill and parsley.",
    "Halve the cherry tomatoes and finely chop the nuka-pickle.",
    "In a large bowl, combine paneer, cucumber, tomatoes, bell pepper, pickle, dill, and parsley.",
    "Whisk together lemon juice, olive oil, salt, and pepper to make the dressing.",
    "Pour the dressing over the salad and toss gently to coat all ingredients.",
    "Refrigerate the salad for at least 10 minutes to allow flavors to meld.",
    "Serve chilled, optionally garnishing with extra dill or lemon wedges."
  ],
