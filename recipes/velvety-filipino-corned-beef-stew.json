      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "carrot",
      "amount": "1 medium",
      "notes": "peeled and diced"
    },
    {
      "name": "frozen peas",
      "amount": "1/2 cup"
    },
    {
      "name": "bay leaves",
      "amount": "2"
    },
    {
      "name": "beef broth, low-sodium",
      "amount": "1½ cups"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
