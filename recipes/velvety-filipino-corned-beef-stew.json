      "amount": "1 teaspoon",
      "notes": "optional"
    },
    {
      "name": "salt and pepper",
      "amount": "to taste"
    },
    {
      "name": "cilantro",
      "amount": "2 tablespoons",
      "notes": "chopped, for garnish"
    }
  ],
  "instructions": [
    "Heat the oil in a large pot over medium heat.",
    "Add the onion and garlic, sautéing until the onion is translucent, about 3 minutes.",
    "Stir in the chopped corned beef and cook for 2 minutes to brown slightly.",
    "Add the diced carrot and peas, then stir to combine.",
    "Pour in the beef broth and bring the mixture to a gentle boil.",
    "Add the soy sauce, fish sauce, tomato paste, bay leaves, and coconut milk; reduce heat to low.",
    "Simmer uncovered for 25 minutes, stirring occasionally, until the vegetables are tender and the sauce thickens to a velvety consistency.",
    "Season with salt and pepper to taste, remove the bay leaves, and serve hot garnished with chopped cilantro."
  ],
