{
  "title": "Velvety Filipino Corned Beef Stew",
  "description": "A rich, creamy corned beef stew with a velvety texture and savory umami flavors, perfect for a romantic Filipino dinner.",
  "cuisine": "Filipino",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
