{
  "title": "Velvety Cozy Green Cardamom Pods Stir-fry",
  "description": "An earthy and velvety Vietnamese dish featuring green cardamom pods, perfectly complemented with a low-carb-friendly twist.",
  "cuisine": "Vietnamese",
  "diet": [
    "low-carb"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Green Cardamom Pods",
      "amount": "6"
    },
    {
      "name": "Onion",
      "amount": "1/4 cup finely chopped"
    },
    {
      "name": "Garlic Cloves",
      "amount": "3 cloves, minced"
    },
    {
      "name": "Rice Wine Vinegar",
      "amount": "2 tablespoons"
    },
    {
      "name": "Coconut Milk",
      "amount": "1/2 cup"
    },
    {
      "name": "Fish Sauce (optional)",
      "amount": "to taste"
    },
    {
      "name": "Lemon Zest",
      "amount": "1 tablespoon, finely grated"
    },
    {
      "name": "Fresh Mint Leaves",
      "amount": "1 handful, chopped"
    },
    {
      "name": "Minced Ginger",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat a large skillet over medium heat.",
    "Add finely chopped onion and minced garlic to the skillet. Cook until translucent.",
    "Fold in green cardamom pods and stir-fry for about 1 minute.",
    "Pour in rice wine vinegar, coconut milk, and optional fish sauce. Simmer gently.",
    "Stir in lemon zest and fresh mint leaves. Adjust seasoning with salt if needed.",
    "Garnish with minced ginger before serving hot."
  ],
