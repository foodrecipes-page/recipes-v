{
  "title": "Velvety Beef Stir-fry",
  "description": "This velvety beef stir-fry is a cozy Mexican (Oaxacan) dish featuring a rich, buttery beef gravy with a touch of Mexican spices and a creamy dairy-free sauce.",
  "cuisine": "Mexican (Oaxacan)",
  "diet": [
    "dairy-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Beef",
      "amount": "200g"
    },
    {
      "name": "Bell Peppers",
      "amount": "1 medium each, diced"
    },
    {
      "name": "Onions",
      "amount": "1 large, finely chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "Tomato Sauce",
      "amount": "200ml (approx. 1 cup)"
    },
    {
      "name": "Cumin",
      "amount": "1/2 tsp"
    },
    {
      "name": "Mexican Spice Mix",
      "amount": "1/4 tsp"
    },
    {
      "name": "Vegetable Oil",
      "amount": "1 tbsp"
    },
    {
      "name": "Balsamic Vinegar",
      "amount": "15ml (approx. 1 Tbsp)"
    },
    {
      "name": "Dijon Mustard",
      "amount": "2 tsp"
    },
    {
      "name": "Water",
      "amount": "100ml (approx. 3/4 cup)"
    },
    {
      "name": "Nutritional Yeast",
      "amount": "5g",
      "notes": "for a cheesy flavor"
    }
  ],
  "instructions": [
    "Heat oil in a large pan over medium heat.",
    "Add onions and garlic, sauté for about 2 minutes until translucent.",
    "Fold in bell peppers and cook for an additional 3-4 minutes.",
    "Stir in cumin and Mexican spice mix, cooking for another minute.",
    "Pour in tomato sauce, balsamic vinegar, and Dijon mustard. Stir well to combine.",
    "Bring the mixture to a simmer, cover and let it thicken slightly, stirring occasionally.",
    "Gradually add water while continuously stirring until you reach your desired consistency.",
    "Fold in shredded beef and cook for 5-7 minutes or until heated through.",
    "Stir in nutritional yeast for added richness and cheesy flavor."
  ],
