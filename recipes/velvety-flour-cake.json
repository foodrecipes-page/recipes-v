    },
    {
      "name": "3 large eggs",
      "amount": "3 eggs"
    },
    {
      "name": "1 cup heavy whipping cream",
      "amount": "1 cup"
    },
    {
      "name": "2 tablespoons butter, melted",
      "amount": "2 tbsp"
