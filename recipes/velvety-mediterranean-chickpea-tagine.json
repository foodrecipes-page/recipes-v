{
  "title": "Velvety Mediterranean Chickpea Tagine",
  "description": "A creamy, fermented chickpea tagine with a buttery bhuna base, perfect for a sick day with no added sugar.",
  "cuisine": "Mediterranean",
  "diet": [
    "vegetarian",
    "sugar-free",
    "sick-day-friendly"
  ],
