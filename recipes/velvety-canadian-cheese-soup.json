      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "2 cloves garlic, minced",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "1 red bell pepper, diced",
      "amount": "1",
      "notes": "diced"
    },
    {
      "name": "1 tsp mixed spice blend (cumin, smoked paprika, cayenne)",
      "amount": "1 tsp",
      "notes": "blend"
    },
    {
      "name": "1 cup low sodium vegetable broth",
      "amount": "1 cup",
      "notes": "low sodium"
    },
    {
