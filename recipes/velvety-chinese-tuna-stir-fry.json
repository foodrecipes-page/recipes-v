  "ingredients": [
    {
      "name": "Tuna",
      "amount": "1 can (400g)",
      "notes": "Drain and rinse"
    },
    {
      "name": "Water chestnuts",
      "amount": "20g",
      "notes": "Soaked in water for 30 minutes"
    },
    {
      "name": "Green onions",
      "amount": "15g",
      "notes": "Chopped finely"
    },
    {
      "name": "Soy sauce",
      "amount": "30ml"
    },
    {
      "name": "Olive oil",
      "amount": "20ml"
    },
    {
      "name": "Garlic",
      "amount": "4 cloves",
      "notes": "Minced"
    },
    {
      "name": "Ginger",
      "amount": "10g",
      "notes": "Grated finely"
    },
    {
      "name": "Shallots",
      "amount": "2 pieces",
      "notes": "Sliced thinly"
    }
  ],
  "instructions": [
    "Heat olive oil in a wok or large skillet over medium-high heat.",
    "Add garlic, ginger, and shallots; sauté for about 1 minute until fragrant.",
    "Push the vegetables to one side of the pan, add tuna, and cook until it's heated through, stirring occasionally (about 2 minutes).",
    "Stir in soy sauce evenly over the tuna, then mix in water chestnuts. Cook for another 2-3 minutes until the sauce starts thickening.",
    "Garnish with chopped green onions before serving."
  ],
