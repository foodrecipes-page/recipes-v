{
  "title": "Velvety Umami Turkish Scamorza Pide",
  "description": "A tender and umami-rich Turkish dish featuring scamorza cheese, perfect for a date night, with a diabetic-friendly twist",
  "cuisine": "Turkish",
  "diet": [
    "diabetic-friendly",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "scamorza cheese",
      "amount": "8 oz",
      "notes": "smoked or regular"
    },
    {
      "name": "rendered lamb fat",
      "amount": "2 tbsp"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "pide bread",
      "amount": "1 lb",
      "notes": "homemade or store-bought"
    },
    {
      "name": "kalamata olives",
      "amount": "1/4 cup",
      "notes": "pitted"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "sumac",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit",
    "Roll out the pide bread to a thickness of about 1/4 inch",
    "Spread the rendered lamb fat evenly over the bread, leaving a 1 inch border around the edges",
    "Top the bread with sliced onion, minced garlic, and pitted kalamata olives",
    "Slice the scamorza cheese into thin strips and place on top of the onion mixture",
    "Sprinkle sumac and chopped parsley over the cheese",
    "Fold the edges of the bread over the filling to form a crust",
    "Bake the pide for 25-30 minutes, or until the crust is golden brown and the cheese is melted and bubbly"
  ],
