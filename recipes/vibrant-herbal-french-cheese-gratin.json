      "amount": "1 tablespoon chopped"
    },
    {
      "name": "Fresh Rosemary",
      "amount": "1 tablespoon chopped"
    },
    {
      "name": "Garlic Powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Black Pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "Butter four 6-ounce ramekins and set them aside.",
    "In a large skillet, saute the diced onion, carrot, and celery over medium heat until the vegetables are tender.",
    "Add the chopped thyme and rosemary to the skillet and cook for an additional minute.",
    "Stir in the garlic powder, salt, and black pepper.",
    "Divide the cooked mirepoix mixture among the prepared ramekins.",
    "Top each ramekin with shredded Monterey Jack cheese.",
    "Bake the gratins in the preheated oven for 20 minutes, or until the cheese is melted and bubbly."
  ],
