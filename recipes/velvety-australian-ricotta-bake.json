{
  "title": "Velvety Australian Ricotta Bake",
  "description": "A romantic, low-fat Australian dish featuring ricotta, perfect for a cozy dinner. This bake is salty, velvety, and sure to impress.",
  "cuisine": "Australian",
  "diet": [
    "low-fat",
    "vegetarian"
  ],
