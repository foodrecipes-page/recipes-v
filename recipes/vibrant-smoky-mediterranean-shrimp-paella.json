      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 400 degrees Fahrenheit.",
    "Heat olive oil in a large skillet over medium-high heat.",
    "Add onion and garlic and cook until the onion is translucent.",
    "Add smoked paprika and cook for 1 minute.",
    "Add shrimp and cook until they are pink and fully cooked.",
    "In a separate bowl, whisk together chicken broth, shrimp stock, saffron threads, salt, and pepper.",
    "Pour the broth mixture over the shrimp and onion mixture.",
    "Transfer the skillet to the preheated oven and bake for 15 minutes.",
    "Remove from oven and let cool for 5 minutes before serving."
  ],
