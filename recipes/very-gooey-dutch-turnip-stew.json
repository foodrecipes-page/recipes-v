      "name": "turnips",
      "amount": "2 large",
      "notes": "peeled and cubed"
    },
    {
      "name": "nuka-pickle",
      "amount": "1 cup",
      "notes": "chopped"
    },
    {
      "name": "onions",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "carrots",
      "amount": "2 large",
      "notes": "peeled and sliced"
    },
    {
      "name": "potatoes",
      "amount": "2 large",
      "notes": "peeled and cubed"
    },
    {
      "name": "vegetable broth",
      "amount": "4 cups"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pot over medium heat.",
    "Add the chopped onions and cook until they are softened.",
    "Add the chopped nuka-pickle and cook for an additional 2 minutes.",
    "Add the turnips, carrots, and potatoes, and cook for 5 minutes.",
    "Pour in the vegetable broth and bring the mixture to a boil.",
    "Reduce the heat to low and simmer the stew for 20 minutes.",
    "Season the stew with salt and black pepper to taste.",
    "Serve the stew hot, garnished with chopped fresh herbs if desired."
  ],
