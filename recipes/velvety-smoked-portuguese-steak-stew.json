  "ingredients": [
    {
      "name": "lean minced steak",
      "amount": "1 pound",
      "notes": "preferably grass-fed"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "dijon mustard",
      "amount": "1 tablespoon"
    },
    {
      "name": "coconut cream",
      "amount": "1 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat",
    "Add the chopped onion and cook until softened, about 5 minutes",
    "Add the minced garlic and cook for an additional minute",
    "Add the lean minced steak and cook until browned, breaking it up into small pieces as it cooks",
    "Add the smoked paprika, dijon mustard, salt, and black pepper, and stir to combine",
    "Pour in the coconut cream and bring the mixture to a simmer",
    "Reduce the heat to low and let the stew cook, covered, for 20 minutes",
    "Stir in the chopped fresh parsley and serve hot"
  ],
