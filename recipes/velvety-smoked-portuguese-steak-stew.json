{
  "title": "Velvety Smoked Portuguese Steak Stew",
  "description": "A mustardy and creamy Portuguese dish featuring lean minced steak, smoke, and satvik-friendly ingredients, perfect for a romantic dinner",
  "cuisine": "Portuguese",
